@page "/"

<PageTitle>DocKit — Blazor WASM Docs Template</PageTitle>

<section class="hero">
    <h1>DocKit</h1>
    <p class="hero-subtitle">
        A minimal, responsive documentation &amp; showcase template for Blazor WebAssembly —
        deployable to GitHub Pages in minutes.
    </p>
    <div class="hero-actions">
        <a href="docs" class="btn btn-primary">Get Started →</a>
        <a href="demo" class="btn btn-secondary">View Demo</a>
    </div>
</section>

<section class="features">
    <div class="feature-card">
        <div class="feature-icon">📝</div>
        <h3>Markdown Docs</h3>
        <p>Write docs in Markdown with YAML front-matter. The manifest is auto-generated at build time.</p>
    </div>
    <div class="feature-card">
        <div class="feature-icon">🎨</div>
        <h3>Light &amp; Dark Theme</h3>
        <p>Automatic theme detection plus a manual toggle. CSS custom properties make it easy to customize.</p>
    </div>
    <div class="feature-card">
        <div class="feature-icon">📱</div>
        <h3>Responsive Layout</h3>
        <p>Sidebar navigation collapses to a drawer on mobile. Table of contents on wide viewports.</p>
    </div>
    <div class="feature-card">
        <div class="feature-icon">🚩</div>
        <h3>Feature Flags</h3>
        <p>Built-in <code>FeatureGate</code> component lets you show or hide content based on runtime flags.</p>
    </div>
    <div class="feature-card">
        <div class="feature-icon">🚀</div>
        <h3>GitHub Pages Ready</h3>
        <p>Includes a GitHub Actions workflow that publishes to GitHub Pages automatically on push.</p>
    </div>
    <div class="feature-card">
        <div class="feature-icon">✨</div>
        <h3>Syntax Highlighting</h3>
        <p>Code blocks are highlighted via highlight.js with zero runtime dependencies on the server.</p>
    </div>
</section>
