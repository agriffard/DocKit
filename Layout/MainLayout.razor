@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="layout @(isNavOpen ? "nav-open" : "")">
    <DocKit.Layout.NavMenu IsOpen="isNavOpen" OnToggle="ToggleNav" />
    <main class="content">
        @Body
    </main>
</div>

<button class="theme-toggle" @onclick="ToggleTheme" title="Toggle light/dark theme">
    @(isDark ? "☀️" : "🌙")
</button>

@code {
    private bool isDark;
    private bool isNavOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await JS.InvokeAsync<string>("localStorage.getItem", "theme");
            isDark = stored == "dark";
            await ApplyTheme();
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        isDark = !isDark;
        await ApplyTheme();
        await JS.InvokeVoidAsync("localStorage.setItem", "theme", isDark ? "dark" : "light");
    }

    private async Task ApplyTheme()
    {
        await JS.InvokeVoidAsync("document.documentElement.setAttribute", "data-theme", isDark ? "dark" : "light");
    }

    private void ToggleNav()
    {
        isNavOpen = !isNavOpen;
    }
}
