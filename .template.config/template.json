{
  "$schema": "http://json.schemastore.org/template",
  "author": "DocKit",
  "classifications": ["Web", "Blazor", "Docs"],
  "identity": "DocKit.Template",
  "name": "DocKit — Blazor WASM Docs Template",
  "shortName": "dockit",
  "tags": { "language": "C#", "type": "project" },
  "sourceName": "DocKit",
  "symbols": {
    "RepoName": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "",
      "description": "GitHub repository name (used for base-href on project sites)."
    },
    "IncludeDemo": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include the FeatureGate live demo page."
    },
    "Theme": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        { "choice": "auto" },
        { "choice": "light" },
        { "choice": "dark" }
      ],
      "defaultValue": "auto"
    },
    "IncludeWorkflow": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include the GitHub Actions deploy workflow."
    }
  }
}
